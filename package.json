{
  "name": "@e18e/deopt-monorepo",
  "version": "0.0.0-dev",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Investigates v8/Node.js function deoptimizations.",
  "type": "module",
  "scripts": {
    "copy-license": "for d in packages/*/; do cp LICENSE \"$d/LICENSE\"; done",
    "lint:js": "oxlint packages scripts",
    "lint:format": "oxfmt --check packages scripts",
    "lint": "npm run lint:js && npm run lint:format",
    "format": "oxfmt --write packages scripts",
    "update-v8-tools": "node scripts/update-v8-tools.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/e18e/deopt.git"
  },
  "homepage": "https://github.com/e18e/deopt",
  "keywords": [],
  "author": "James Garbutt (https://github.com/43081j)",
  "license": "MIT",
  "engine": {
    "node": ">=20"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  }
}
