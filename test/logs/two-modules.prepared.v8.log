script-source,88,file:///Users/jg/code/deoptigate/examples/two-modules/objects.js,class Object1 {\n  constructor(x\x2C y) {\n    this.x = x\n    this.y = y\n  }\n}\n\nclass Object2 {\n  constructor(x\x2C y) {\n    this.y = y\n    this.x = x\n  }\n}\n\nclass Object3 {\n  constructor(x\x2C y) {\n    this.hello = 'world'\n    this.x = x\n    this.y = y\n  }\n}\n\nclass Object4 {\n  constructor(x\x2C y) {\n    this.x = x\n    this.hello = 'world'\n    this.y = y\n  }\n}\n\nclass Object5 {\n  constructor(x\x2C y) {\n    this.x = x\n    this.y = y\n    this.hello = 'world'\n  }\n}\n\nclass Object6 {\n  constructor(x\x2C y) {\n    this.hola = 'mundo'\n    this.x = x\n    this.y = y\n    this.hello = 'world'\n  }\n}\n\nclass Object7 {\n  constructor(x\x2C y) {\n    this.x = x\n    this.hola = 'mundo'\n    this.y = y\n    this.hello = 'world'\n  }\n}\n\nclass Object8 {\n  constructor(x\x2C y) {\n    this.x = x\n    this.y = y\n    this.hola = 'mundo'\n    this.hello = 'world'\n  }\n}\n\nexport {\n    Object1\n  \x2C Object2\n  \x2C Object3\n  \x2C Object4\n  \x2C Object5\n  \x2C Object6\n  \x2C Object7\n  \x2C Object8\n}\n
