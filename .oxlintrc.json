{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "packages/processor/lib/vendor/**"
  ],
  "plugins": [
    "typescript",
    "oxc"
  ],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "rules": {
    "no-await-in-loop": "off",
    "no-underscore-dangle": ["error", {
      "allowFunctionParams": true
    }]
  },
  "env": {
    "builtin": true
  }
}
