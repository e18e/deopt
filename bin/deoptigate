#!/usr/bin/env node

import { styleText } from 'node:util'

import { openLog } from './deoptigate.open-log.js'
import { findLog } from './deoptigate.find-log.js'
import { createLog } from './deoptigate.create-log.js'

const simpleHead = styleText('blue', 'deoptigate')
const happyHead = styleText('blue', 'deoptigate 💪')
const errorHead = styleText('red', 'deoptigate 🚫')

try {
  const log = (process.argv.length <= 2
    ? await findLog(happyHead)
    : await createLog(process.argv.slice(2), happyHead, simpleHead)
  )
  await openLog(log, happyHead)
} catch (err) {
  console.error(`${errorHead}: ${err}`)
}
